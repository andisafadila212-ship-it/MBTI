    <div class="mini-cat-bubble" id="neko-hint">Jawab dengan jujur ya~ Tidak ada jawaban yang salah! 🌸</div>
  </div>

  <div class="q-card" id="q-card">
    <div class="section-tag tag-mbti" id="q-tag">🧠 MBTI</div>
    <div class="q-number" id="q-number">Pertanyaan 1</div>
    <div class="q-text" id="q-text"></div>
    <div class="options-grid" id="options-grid"></div>
  </div>

  <div class="nav-row">
    <button class="btn-nav btn-prev" id="btn-prev" onclick="prevQ()">← Kembali</button>
    <button class="btn-nav btn-next" id="btn-next" onclick="nextQ()" disabled>Lanjut →</button>
  </div>
</div>

<!-- RESULT -->
<div class="screen" id="screen-result">
  <div class="result-header">
    <div class="mini-cat" style="justify-content:center;margin-bottom:1rem">
      <svg style="width:56px;height:56px;animation:cat-bounce 2s ease-in-out infinite" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
        <ellipse cx="100" cy="88" rx="52" ry="48" fill="#e8d5f5"/>
        <polygon points="55,55 42,22 72,42" fill="#e8d5f5"/><polygon points="145,55 158,22 128,42" fill="#e8d5f5"/>
        <polygon points="58,52 48,28 70,44" fill="#f4b8cb"/><polygon points="142,52 152,28 130,44" fill="#f4b8cb"/>
        <ellipse cx="83" cy="86" rx="12" ry="13" fill="white"/><ellipse cx="117" cy="86" rx="12" ry="13" fill="white"/>
        <ellipse cx="85" cy="88" rx="8" ry="7" fill="#6b3fa0"/><ellipse cx="119" cy="88" rx="8" ry="7" fill="#6b3fa0"/>
        <circle cx="87" cy="85" r="3" fill="white"/><circle cx="121" cy="85" r="3" fill="white"/>
        <ellipse cx="100" cy="100" rx="5" ry="4" fill="#f4b8cb"/>
        <path d="M95 105 Q100 110 105 105" stroke="#c4527a" stroke-width="2" fill="none" stroke-linecap="round"/>
        <ellipse cx="74" cy="98" rx="9" ry="6" fill="#f4b8cb" opacity="0.5"/>
        <ellipse cx="126" cy="98" rx="9" ry="6" fill="#f4b8cb" opacity="0.5"/>
      </svg>
    </div>
    <p style="font-size:13px;color:var(--text-soft);margin-bottom:0.5rem">Tipe kepribadianmu adalah</p>
    <h1 class="result-title"><span class="mbti-type" id="res-type">INFP</span></h1>
    <p style="font-size:1rem;color:var(--text-mid);font-weight:600;margin-top:4px" id="res-nickname"></p>
  </div>

  <div class="result-grid">
    <div class="result-card full">
      <div class="rc-label">Gambaran Kepribadian</div>
      <div class="rc-desc" id="res-desc" style="font-size:14px;color:var(--text-dark)"></div>
    </div>

    <div class="result-card">
      <div class="rc-label">Profil Dimensi MBTI</div>
      <div class="trait-bar" id="trait-bars"></div>
    </div>

    <div class="result-card">
      <div class="rc-label">Area Pertumbuhan Diri</div>
      <div class="trauma-tags" id="res-trauma"></div>
      <p style="font-size:12px;color:var(--text-soft);margin-top:10px;line-height:1.6" id="res-trauma-desc"></p>
    </div>

    <div class="result-card full">
      <div class="rc-label">Saran untuk Kamu 🌱</div>
      <ul class="advice-list" id="res-advice"></ul>
    </div>
  </div>

  <button class="btn-restart" onclick="restartTest()">Coba Lagi ↺</button>
  <p class="footer-credit">MindScape · Dibuat dengan ❤ oleh Andoy · Semua data bersifat lokal</p>
</div>

</div><!-- wrapper -->

<script>
const questions = [
  // MBTI - E/I
  { type:'EI', text:'Setelah hari yang panjang, kamu lebih suka...', tag:'🧠 MBTI — Energi', hint:'Pikirkan kebiasaan harianmu~', opts:['Ngobrol dan hang out bersama teman-teman','Sendirian di kamar, rebahan dan merenung','Sedikit sosialisasi, lalu menyendiri','Tergantung energi yang aku punya'], scores:[0,4,3,2] },
  { type:'EI', text:'Di kelas atau tempat kerja, kamu biasanya...', tag:'🧠 MBTI — Energi', hint:'Bagaimana caramu berinteraksi dengan orang lain?', opts:['Aktif bicara dan sering mengangkat tangan','Lebih banyak mendengar dan mengamati','Bicara kalau diminta atau ada topik yang aku kuasai','Pilih-pilih orang untuk diajak bicara'], scores:[0,4,2,3] },

  // MBTI - S/N
  { type:'SN', text:'Saat belajar hal baru, kamu lebih tertarik pada...', tag:'🧠 MBTI — Persepsi', hint:'Apa yang paling membuatmu penasaran?', opts:['Fakta, detail, dan cara kerja praktisnya','Konsep besar, makna, dan kemungkinan di baliknya','Keduanya, tergantung topiknya','Hal yang terasa relevan dengan hidupku'], scores:[0,4,2,3] },
  { type:'SN', text:'Ketika membayangkan masa depan, kamu cenderung...', tag:'🧠 MBTI — Persepsi', hint:'Bagaimana pikiranmu bekerja saat merencanakan?', opts:['Fokus pada rencana konkret dan realistis','Mimpi besar dan penuh kemungkinan tak terbatas','Gabungan mimpi dengan langkah nyata','Menghindari memikirkan jauh ke depan'], scores:[0,4,2,3] },

  // MBTI - T/F
  { type:'TF', text:'Ketika temanmu punya masalah, reaksi pertamamu...', tag:'🧠 MBTI — Keputusan', hint:'Apa yang secara alami kamu lakukan?', opts:['Langsung bantu cari solusi dan analisis masalah','Mendengarkan dan merasakan apa yang mereka rasakan','Tanya lebih dulu, baru putuskan bagaimana bantu','Diam tapi diam-diam khawatir'], scores:[0,4,2,3] },
  { type:'TF', text:'Dalam mengambil keputusan besar, kamu lebih mengandalkan...', tag:'🧠 MBTI — Keputusan', hint:'Apa yang menjadi kompasmu?', opts:['Logika, data, dan analisis objektif','Intuisi, nilai, dan perasaan yang kuat','Konsultasi dengan orang-orang terdekat','Berdoa atau mengikuti keyakinan'], scores:[0,4,3,2] },

  // MBTI - J/P
  { type:'JP', text:'Soal jadwal dan rencana, kamu adalah tipe yang...', tag:'🧠 MBTI — Gaya Hidup', hint:'Bagaimana kamu menjalani keseharianmu?', opts:['Punya to-do list dan jadwal yang tertata','Lebih suka spontan dan fleksibel','Punya rencana tapi sering berubah','Benci perencanaan tapi butuh struktur'], scores:[0,4,2,3] },
  { type:'JP', text:'Ketika mengerjakan tugas atau proyek, kamu biasanya...', tag:'🧠 MBTI — Gaya Hidup', hint:'Bagaimana proses kerjamu?', opts:['Cicil dari jauh-jauh hari, selesai tepat waktu','Lebih produktif di bawah tekanan deadline','Mulai awal tapi sering mentok di tengah','Inspirasi datang tiba-tiba, lalu tancap gas'], scores:[0,4,2,3] },

  // TAMBAHAN MBTI
  { type:'EI', text:'Kamu sedang ada di pesta ramai. Setelah 2 jam, kamu merasa...', tag:'🧠 MBTI — Energi', hint:'Dengarkan tubuh dan pikiranmu~', opts:['Makin bersemangat dan tidak mau pulang','Kelelahan dan mulai mencari sudut yang sepi','Oke-oke saja asalkan ada teman dekat','Sudah cukup, mau pulang tapi tidak enak'], scores:[0,4,2,3] },
  { type:'SN', text:'Kamu lebih suka membaca atau menonton tentang...', tag:'🧠 MBTI — Persepsi', hint:'Apa yang paling menarik perhatianmu?', opts:['Kisah nyata, biografi, dokumenter','Fiksi ilmiah, fantasi, filsafat','Kisah inspiratif dengan pesan mendalam','Apa saja yang relevan dengan situasiku'], scores:[0,4,2,3] },

  // SELF-AWARENESS / TRAUMA RINGAN
  { type:'TR', text:'Ada hal dari masa kecilmu yang hingga kini masih...', tag:'💜 Kesadaran Diri', hint:'Tidak ada jawaban yang salah — jujur ya~', opts:['Membuatku merasa tidak cukup baik','Membuatku sulit percaya orang lain','Membuatku takut konflik atau kecewain orang','Alhamdulillah, masa kecilku cukup baik'], scores:[3,3,3,0] },
  { type:'TR', text:'Ketika dikritik atau dikecewakan orang yang berarti, kamu...', tag:'💜 Kesadaran Diri', hint:'Bagaimana responmu secara natural?', opts:['Langsung merenung panjang dan menyalahkan diri','Marah dulu, baru lama-lama merenung','Pura-pura oke di luar, tapi dalam hati terluka','Bisa menerima dengan cukup baik'], scores:[4,2,3,0] },
  { type:'TR', text:'Dalam hubungan dengan orang lain, hal yang paling sering kamu khawatirkan...', tag:'💜 Kesadaran Diri', hint:'Jujur dengan dirimu sendiri~', opts:['Ditinggalkan atau diabaikan','Dimanfaatkan atau dikhianati','Menjadi beban bagi orang lain','Tidak bisa terhubung secara mendalam'], scores:[3,3,3,2] },
  { type:'TR', text:'Ketika kamu sendirian dan sunyi, pikiranmu sering melayang ke...', tag:'💜 Kesadaran Diri', hint:'Perhatikan polamu~', opts:['Penyesalan dan hal-hal di masa lalu','Kekhawatiran tentang masa depan','Perasaan bahwa ada yang "kurang" dalam diriku','Rencana, ide, dan hal-hal yang ingin dilakukan'], scores:[3,3,3,0] },
  { type:'TR', text:'Saat kamu membutuhkan dukungan emosional, kamu biasanya...', tag:'💜 Kesadaran Diri', hint:'Bagaimana kamu mencari pertolongan?', opts:['Sulit membuka diri, lebih banyak menyimpan sendiri','Berbagi dengan sangat selektif, hanya yang paling dipercaya','Mudah bercerita tapi ragu apakah layak didengar','Cukup terbuka dan tidak sungkan minta bantuan'], scores:[4,3,2,0] },

  // POLA PIKIR SISWA
  { type:'EI', text:'Di lingkungan belajar, kamu lebih berkembang ketika...', tag:'🎓 Pola Belajar', hint:'Pikirkan saat belajarmu paling efektif!', opts:['Ada diskusi kelompok dan interaksi aktif','Belajar mandiri dengan buku atau video','Ada mentor yang membimbing satu per satu','Bisa gabungkan sendiri dan kelompok sesuai mood'], scores:[0,4,3,2] },
  { type:'SN', text:'Ketika belajar materi baru, kamu lebih mudah paham kalau...', tag:'🎓 Pola Belajar', hint:'Metode belajar apa yang paling cocok?', opts:['Ada contoh konkret dan latihan langsung','Ada penjelasan konsep dan "kenapa"-nya dulu','Ada peta konsep yang menghubungkan semuanya','Dicoba sendiri dulu, baru baca teorinya'], scores:[0,4,3,2] },
  { type:'TF', text:'Saat dapat nilai buruk, reaksi pertamamu adalah...', tag:'🎓 Pola Belajar', hint:'Bagaimana kamu merespons kegagalan?', opts:['Langsung analisis kesalahan dan buat rencana perbaikan','Kecewa dan butuh waktu untuk "move on"','Cari tahu faktor penyebabnya baru bertindak','Jadikan motivasi untuk lebih keras berusaha'], scores:[0,3,2,1] },
  { type:'JP', text:'Dalam mengerjakan tugas besar, kamu biasanya...', tag:'🎓 Pola Belajar', hint:'Apa gaya pendekatanmu?', opts:['Buat outline detail dulu sebelum mulai','Langsung mulai menulis dan lihat nanti','Riset dulu sampai puas baru mulai nulis','Kerjakan bagian yang mudah dulu baru yang susah'], scores:[0,4,3,2] },

  // MINDSET & NILAI
  { type:'SN', text:'Kamu percaya bahwa kesuksesan seseorang terutama ditentukan oleh...', tag:'🌟 Nilai & Mindset', hint:'Apa keyakinan dasarmu?', opts:['Kerja keras, disiplin, dan konsistensi','Bakat, visi, dan kreativitas bawaan','Koneksi, lingkungan, dan kesempatan','Kombinasi semua faktor di atas'], scores:[0,3,2,1] },
  { type:'TF', text:'Ketika melihat seseorang gagal, pikiran pertamamu...', tag:'🌟 Nilai & Mindset', hint:'Bagaimana perspektifmu?', opts:['Pasti ada yang salah dari caranya atau keputusannya','Kasihan, pasti berat rasanya','Kegagalan itu bagian dari proses, bisa bangkit','Tergantung konteks dan penyebabnya'], scores:[1,3,1,1] },
  { type:'EI', text:'Bagaimana kamu biasanya merayakan pencapaian?', tag:'🌟 Nilai & Mindset', hint:'Rayakan dirimu sendiri dulu!', opts:['Bagi kegembiraan dengan banyak orang','Diam-diam bersyukur, mungkin cerita ke satu dua orang','Hadiah untuk diri sendiri','Langsung fokus ke target berikutnya'], scores:[0,4,2,1] },
  { type:'TR', text:'Hal yang paling sering membuatmu merasa "tidak layak" atau insecure adalah...', tag:'💜 Kesadaran Diri', hint:'Kenali ketakutan terdalammu~', opts:['Tidak sepintar atau sesukses orang lain','Tidak dicintai atau diterima apa adanya','Tidak produktif atau tidak berguna','Tidak punya tujuan yang jelas dalam hidup'], scores:[3,4,3,2] },
  { type:'TR', text:'Jika kamu bisa berbicara dengan dirimu di masa kecil, kamu akan berkata...', tag:'💜 Kesadaran Diri', hint:'Ini adalah cermin jiwa yang dalam~', opts:['"Kamu cukup, kamu layak dicintai apa adanya"','"Jangan takut gagal, cobakan saja"','"Tidak apa-apa untuk meminta bantuan"','"Kamu lebih kuat dari yang kamu kira"'], scores:[4,2,3,2] },
];

let answers = new Array(questions.length).fill(null);
let currentIdx = 0;

const catHints = [
  "Jawab dengan jujur ya~ Tidak ada jawaban yang salah! 🌸",
  "Santai aja, ini bukan ujian! 🐾",
  "Kamu doing great! Terus ya~ ✨",
  "Aku di sini menemanimu~ 💜",
  "Pertanyaan ini mungkin dalam, tapi kamu kuat! 🌙",
  "Hampir sampai! Tetap jujur ya~ 🌟",
  "Kamu keren banget mau mengenal dirimu lebih dalam! 🎉"
];

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => { s.classList.remove('active'); });
  const el = document.getElementById(id);
  el.classList.add('active');
  el.classList.add('screen-transition');
  setTimeout(() => el.classList.remove('screen-transition'), 500);
}

function startTest() {
  answers = new Array(questions.length).fill(null);
  currentIdx = 0;
  showScreen('screen-quiz');
  renderQuestion();
}

function renderQuestion() {
  const q = questions[currentIdx];
  const pct = Math.round((currentIdx / questions.length) * 100);
  document.getElementById('prog-label').textContent = `Pertanyaan ${currentIdx + 1} dari ${questions.length}`;
  document.getElementById('prog-pct').textContent = pct + '%';
  document.getElementById('prog-fill').style.width = pct + '%';

  document.getElementById('q-tag').textContent = q.tag;
  document.getElementById('q-tag').className = 'section-tag ' + (q.type === 'TR' ? 'tag-trauma' : 'tag-mbti');
  document.getElementById('q-number').textContent = `Pertanyaan ${currentIdx + 1}`;
  document.getElementById('q-text').textContent = q.text;

  const hintIdx = Math.floor(currentIdx / 3) % catHints.length;
  document.getElementById('neko-hint').textContent = catHints[hintIdx];

  const grid = document.getElementById('options-grid');
  grid.innerHTML = '';
  q.opts.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'opt-btn' + (answers[currentIdx] === i ? ' selected' : '');
    btn.innerHTML = `<span class="opt-letter">${String.fromCharCode(65+i)}</span>${opt}`;
    btn.onclick = () => selectOpt(i);
    grid.appendChild(btn);
  });

  document.getElementById('btn-prev').disabled = currentIdx === 0;
  document.getElementById('btn-next').disabled = answers[currentIdx] === null;
  document.getElementById('btn-next').textContent = currentIdx === questions.length - 1 ? 'Lihat Hasilku ✨' : 'Lanjut →';

  // Re-animate card
  const card = document.getElementById('q-card');
  card.style.animation = 'none';
  card.offsetHeight;
  card.style.animation = 'card-in 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) both';
}

function selectOpt(i) {
  answers[currentIdx] = i;
  document.querySelectorAll('.opt-btn').forEach((b, idx) => {
    b.classList.toggle('selected', idx === i);
  });
  document.getElementById('btn-next').disabled = false;
}

function nextQ() {
  if (answers[currentIdx] === null) return;
  if (currentIdx === questions.length - 1) {
    showLoading();
    return;
  }
  currentIdx++;
  renderQuestion();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function prevQ() {
  if (currentIdx > 0) { currentIdx--; renderQuestion(); }
}

function showLoading() {
  showScreen('screen-loading');
  const msgs = ['Memproses jawabanmu...', 'Menganalisis pola pikiranmu...', 'Merangkai hasil yang personal...', 'Hampir selesai~ 🌸'];
  let mi = 0;
  const iv = setInterval(() => {
    mi++;
    if (mi < msgs.length) document.getElementById('loading-text').textContent = msgs[mi];
  }, 700);
  setTimeout(() => { clearInterval(iv); calculateResult(); }, 3000);
}

function calculateResult() {
  let E=0,I=0,S=0,N=0,T=0,F=0,J=0,P=0,trauma=0;

  questions.forEach((q, idx) => {
    if (answers[idx] === null) return;
    const s = q.scores[answers[idx]];
    if (q.type === 'EI') { if(s<=2) E+=4-s; else I+=s; }
    else if (q.type === 'SN') { if(s<=1) S+=3; else N+=s; }
    else if (q.type === 'TF') { if(s<=1) T+=3; else F+=s; }
    else if (q.type === 'JP') { if(s<=1) J+=3; else P+=s; }
    else if (q.type === 'TR') { trauma += s; }
  });

  const type = (E>=I?'E':'I') + (N>=S?'N':'S') + (F>=T?'F':'T') + (P>=J?'P':'J');

  const total_ei = E+I || 1, total_sn = S+N || 1, total_tf = T+F || 1, total_jp = J+P || 1;
  const scores = {
    E: Math.round((E/total_ei)*100), I: Math.round((I/total_ei)*100),
    S: Math.round((S/total_sn)*100), N: Math.round((N/total_sn)*100),
    T: Math.round((T/total_tf)*100), F: Math.round((F/total_tf)*100),
    J: Math.round((J/total_jp)*100), P: Math.round((P/total_jp)*100),
  };

  showResult(type, scores, trauma);
}

const mbtiData = {
  INFP: { nick:'The Dreamer — Si Pemimpi Idealis', desc:'Kamu adalah jiwa yang kaya akan imajinasi dan nilai-nilai mendalam. Kamu peduli pada makna, autentisitas, dan dunia yang lebih baik. Kamu peka terhadap orang lain dan memiliki empati yang dalam, namun kadang terlalu keras pada diri sendiri.', advice:['Belajar menerima dirimu apa adanya — kamu tidak harus sempurna untuk layak dicintai','Ekspresikan perasaanmu melalui tulisan, seni, atau percakapan yang bermakna','Kenali batas energimu dan izinkan dirimu untuk beristirahat tanpa rasa bersalah'] },
  INFJ: { nick:'The Advocate — Si Pembela yang Bijak', desc:'Kamu langka dan visioner. Kamu melihat dunia melalui lensa makna dan koneksi manusia. Kamu mendorong orang lain untuk berkembang sambil menjaga nilai-nilaimu yang kuat. Perlu hati-hati agar tidak terlalu menanggung beban orang lain.', advice:['Luangkan waktu untuk dirimu sendiri — bukan egois, tapi perlu','Ceritakan kebutuhanmu pada orang-orang terdekat','Percayai prosesmu meski jalannya tidak selalu lurus'] },
  INTJ: { nick:'The Architect — Si Perencana Jenius', desc:'Pikiran strategismu adalah kekuatan terbesar. Kamu mandiri, logis, dan selalu punya rencana. Kamu bekerja keras untuk mewujudkan visi besar, tapi kadang kesulitan terhubung secara emosional dengan orang lain.', advice:['Latih dirimu untuk mendengar perspektif orang lain tanpa menghakimi','Buka sedikit ruang untuk spontanitas — tidak semua hal perlu direncanakan','Emosi bukan kelemahan; mereka adalah data yang berharga'] },
  INTP: { nick:'The Thinker — Si Pemikir Logis', desc:'Pikiranmu seperti mesin analisis yang tidak pernah berhenti. Kamu menikmati eksplorasi ide dan sistem yang kompleks. Kamu skeptis, kreatif, dan original — tapi mungkin kesulitan menerjemahkan ide ke tindakan nyata.', advice:['Tetapkan deadline kecil untuk dirimu agar ide-idemu terwujud','Hubungan manusia perlu diinvestasikan, bukan hanya dianalisis','Coba ungkapkan perasaanmu, meski terasa canggung'] },
  ENFP: { nick:'The Campaigner — Si Penyebar Semangat', desc:'Energimu menular dan imajinasimu tak terbatas. Kamu mencintai koneksi manusia dan selalu melihat potensi terbaik dalam diri orang lain. Kamu visioner, spontan, dan penuh semangat — kadang sulit fokus pada satu hal.', advice:['Coba selesaikan apa yang kamu mulai sebelum memulai hal baru','Jaga energimu — tidak semua orang perlu kamu "selamatkan"','Fokus pada beberapa prioritas utama daripada banyak hal sekaligus'] },
  ENFJ: { nick:'The Protagonist — Si Pemimpin Empatik', desc:'Kamu adalah pemimpin alami yang peduli pada pertumbuhan orang di sekitarmu. Kamu karismatik, hangat, dan penuh visi. Tapi kadang kebutuhanmu sendiri terabaikan karena terlalu fokus pada orang lain.', advice:['Belajar bilang "tidak" tanpa rasa bersalah','Pastikan kamu juga menerima dukungan, tidak hanya memberi','Rawat dirimu sendiri sebelum merawat orang lain'] },
  ENTP: { nick:'The Debater — Si Penantang Ide', desc:'Pikiran cepatmu selalu mencari sudut pandang baru dan suka menantang status quo. Kamu inovatif, cerdas, dan energetik. Tapi kadang suka berdebat hanya demi berdebat dan melupakan perasaan orang lain.', advice:['Pilih pertempuran yang benar-benar penting','Dengarkan tanpa harus "menang"','Konsistensi adalah kekuatan yang perlu kamu kembangkan'] },
  ENTJ: { nick:'The Commander — Si Pemimpin Tegas', desc:'Kamu lahir untuk memimpin. Efisien, terorganisir, dan penuh ambisi. Kamu melihat setiap masalah sebagai peluang dan bekerja tanpa kenal lelah untuk mencapai tujuan. Hati-hati agar tidak terlalu keras pada diri sendiri dan orang lain.', advice:['Delegasikan dan percaya pada tim — kamu tidak harus melakukan segalanya','Luangkan waktu untuk koneksi emosional yang tulus','Istirahat adalah produktivitas yang sering dilupakan'] },
  ISFP: { nick:'The Artist — Si Seniman yang Bebas', desc:'Kamu hidup di momen ini, penuh sensitivitas dan keindahan. Kamu autentik, hangat, dan menghargai kebebasan. Kamu ekspresi diri melalui tindakan dan karya nyata, bukan kata-kata.', advice:['Percayai dirimu untuk berbicara dan didengar','Rencanakan sedikit untuk masa depan — kamu punya banyak yang bisa ditawarkan','Hubungan yang dalam butuh keberanian untuk membuka diri'] },
  ISFJ: { nick:'The Defender — Si Penjaga yang Setia', desc:'Kamu adalah pilar yang diandalkan banyak orang. Penuh perhatian, setia, dan selalu hadir untuk orang-orang yang kamu cintai. Kamu bekerja keras di balik layar tanpa banyak meminta pengakuan.', advice:['Kamu juga berhak untuk dirawat dan diperhatikan','Ungkapkan kebutuhanmu — orang-orang sekitarmu mungkin tidak sadar','Jangan biarkan rasa takut perubahan menghambat pertumbuhanmu'] },
  ISTP: { nick:'The Virtuoso — Si Pemecah Masalah', desc:'Tenang, analitis, dan sangat efektif dalam krisis. Kamu belajar melalui pengalaman langsung dan unggul dalam bidang teknis. Tapi kadang sulit membagi apa yang ada di dalam hatimu.', advice:['Buka sedikit tentang perasaanmu pada orang-orang yang kamu percaya','Relasi yang bermakna butuh waktu dan usaha','Jangan hanya tunggu situasi "darurat" untuk menunjukkan kepedulianmu'] },
  ISTJ: { nick:'The Logistician — Si Penjaga Tradisi', desc:'Andalan dalam setiap situasi. Kamu bertanggung jawab, detail-oriented, dan selalu menepati janji. Kamu membangun kepercayaan melalui konsistensi dan kerja keras. Fleksibilitas adalah area yang bisa kamu kembangkan.', advice:['Berikan ruang untuk cara-cara baru meski berbeda dari biasanya','Ekspresi emosi adalah kekuatan, bukan kelemahan','Kamu berhak untuk bersantai sesekali tanpa rasa bersalah'] },
  ESFP: { nick:'The Entertainer — Si Pembawa Keceriaan', desc:'Hidupmu adalah perayaan. Energetik, hangat, dan spontan — kamu membawa kegembiraan ke mana pun pergi. Kamu terhubung dengan orang lain secara natural dan menikmati momen saat ini.', advice:['Rencanakan sedikit untuk masa depan agar tidak terkejut','Kedalaman juga penting — tidak semua hal harus ringan','Coba hadapi konflik daripada menghindarinya'] },
  ESFJ: { nick:'The Consul — Si Perawat Sosial', desc:'Kamu adalah jantung dari komunitas. Hangat, peduli, dan selalu ada untuk orang lain. Kamu menjaga harmoni dan memastikan semua orang merasa diterima. Tapi kadang kamu butuh validasi eksternal untuk merasa aman.', advice:['Bangun kepercayaan diri yang tidak bergantung pada pendapat orang lain','Belajar menerima kritik sebagai masukan, bukan penolakan','Kebutuhanmu sama pentingnya dengan kebutuhan orang lain'] },
  ESTP: { nick:'The Entrepreneur — Si Petualang Berani', desc:'Energetik, pragmatis, dan selalu siap beraksi. Kamu unggul di lingkungan yang dinamis dan suka tantangan langsung. Kamu observan dan cepat beradaptasi, tapi kadang terlalu impulsif.', advice:['Pertimbangkan konsekuensi jangka panjang sebelum bertindak','Dengarkan perspektif yang berbeda — ada banyak cara untuk menang','Kedalaman emosi adalah aset, bukan hambatan'] },
  ESTJ: { nick:'The Executive — Si Pelaksana Handal', desc:'Terorganisir, tegas, dan efisien. Kamu adalah orang yang membuat sesuatu benar-benar terjadi. Kamu menghargai struktur, aturan, dan tradisi yang terbukti berhasil. Kadang terlalu kaku pada "cara yang benar".', advice:['Ada banyak cara yang benar — buka diri pada pendekatan berbeda','Empati adalah alat kepemimpinan yang sangat kuat','Dengarkan tim sebelum memutuskan'] },
};

const traumaInsights = [
  { level: 'rendah', tags: ['Resiliensi Tinggi', 'Fondasi Kuat', 'Adaptif'], desc: 'Kamu memiliki fondasi emosional yang cukup kuat. Terus rawat kesehatan mentalmu dan jaga koneksi dengan orang-orang yang mendukungmu.' },
  { level: 'sedang', tags: ['Self-Doubt', 'People-Pleasing', 'Butuh Validasi'], desc: 'Ada beberapa pola yang mungkin sudah lama kamu bawa. Mengenalinya adalah langkah pertama yang penting. Berbicara dengan seseorang yang kamu percaya bisa sangat membantu.' },
  { level: 'cukup tinggi', tags: ['Inner Child Wounds', 'Fear of Abandonment', 'Emotional Guard'], desc: 'Beberapa pengalamanmu mungkin telah membentuk cara kamu melihat diri sendiri dan orang lain. Kamu tidak sendirian — dan mencari dukungan adalah tanda kekuatan, bukan kelemahan.' },
  { level: 'perlu perhatian', tags: ['Deep Healing Needed', 'Trust Issues', 'Unmet Core Needs'], desc: 'Kamu membawa beban yang cukup berat. Pertimbangkan untuk berbicara dengan konselor atau psikolog — bukan karena kamu "rusak", tapi karena kamu berhak mendapat dukungan yang tepat.' },
];

function showResult(type, scores, trauma) {
  const data = mbtiData[type] || mbtiData['INFP'];
  const traumaLevel = trauma < 8 ? 0 : trauma < 16 ? 1 : trauma < 24 ? 2 : 3;
  const ti = traumaInsights[traumaLevel];

  document.getElementById('res-type').textContent = type;
  document.getElementById('res-nickname').textContent = data.nick;
  document.getElementById('res-desc').textContent = data.desc;

  const trBars = document.getElementById('trait-bars');
  trBars.innerHTML = `
    <div class="trait-row"><span class="trait-label">E/I</span><div class="trait-track"><div class="trait-fill trait-fill-e" style="width:${scores.E}%"></div></div><span class="trait-pct">${scores.E > scores.I ? 'E '+scores.E+'%' : 'I '+scores.I+'%'}</span></div>
    <div class="trait-row"><span class="trait-label">N/S</span><div class="trait-track"><div class="trait-fill trait-fill-n" style="width:${scores.N}%"></div></div><span class="trait-pct">${scores.N > scores.S ? 'N '+scores.N+'%' : 'S '+scores.S+'%'}</span></div>
    <div class="trait-row"><span class="trait-label">F/T</span><div class="trait-track"><div class="trait-fill trait-fill-f" style="width:${scores.F}%"></div></div><span class="trait-pct">${scores.F > scores.T ? 'F '+scores.F+'%' : 'T '+scores.T+'%'}</span></div>
    <div class="trait-row"><span class="trait-label">P/J</span><div class="trait-track"><div class="trait-fill trait-fill-p" style="width:${scores.P}%"></div></div><span class="trait-pct">${scores.P > scores.J ? 'P '+scores.P+'%' : 'J '+scores.J+'%'}</span></div>
  `;

  document.getElementById('res-trauma').innerHTML = ti.tags.map(t => `<span class="trauma-tag">${t}</span>`).join('');
  document.getElementById('res-trauma-desc').textContent = ti.desc;

  const advList = document.getElementById('res-advice');
  advList.innerHTML = data.advice.map(a => `<li>${a}</li>`).join('');

  showScreen('screen-result');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function restartTest() { startTest(); }
</script>
</body>
</html>
